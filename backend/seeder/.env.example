# URL pública del store-service (requerido — sin default)
STORE_SERVICE_URL=http://TU_IP:8004

# Cantidad de tiendas a crear (default: 10)
NUM_SHOPS=10

# Productos por tienda (default: 200)
PRODUCTS_PER_SHOP=200

# Usuarios normales por tienda (default: 100)
USERS_PER_SHOP=100

# Requests HTTP simultáneos máximos (default: 20)
CONCURRENCY=20
