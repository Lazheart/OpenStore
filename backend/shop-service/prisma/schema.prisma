generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("SHOP_DATABASE_URL") // Prisma 5 sí lee esto directamente
}

model Shop {
  id          Int          @id @default(autoincrement())
  name        String
  owner_id    Int          // Prisma 5 mapea esto tal cual en TS
  memberships Membership[]
}

model Membership {
  id      Int    @id @default(autoincrement())
  user_id String
  role    String
  shop_id Int
  shop    Shop   @relation(fields: [shop_id], references: [id])
}
