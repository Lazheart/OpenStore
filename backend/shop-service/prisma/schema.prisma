generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  // Use a Prisma-compatible URL (protocol `mysql://`). The compose file
  // provides `SHOP_DATABASE_URL_PRISMA` which converts the existing
  // JDBC-style `SHOP_DATABASE_URL` into a `mysql://` URL for Prisma.
  url      = env("SHOP_DATABASE_URL_PRISMA")
}

model Shop {
  id          String       @id @default(uuid())
  name        String       @unique
  owner_id    String
  phone_number String
  memberships Membership[]
}

model Membership {
  id      Int    @id @default(autoincrement())
  user_id String
  role    String
  shop_id String
  shop    Shop   @relation(fields: [shop_id], references: [id])
}
