# ============================================================
# OPENSTORE — DataIngest ENV
# ============================================================
# Copiar como .env en MV-Ingesta y rellenar las vars AWS.
# Todas las IPs son la IP privada de App-1 (misma VPC).

# --- PostgreSQL (user-service) ---
POSTGRES_HOST=172.31.11.149
POSTGRES_PORT=5432
POSTGRES_DB=userdb
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# --- MySQL (shop-service) ---
MYSQL_HOST=172.31.11.149
MYSQL_PORT=3307
MYSQL_DB=shopdb
MYSQL_USER=admin
MYSQL_PASSWORD=admin123

# --- MongoDB (product-service) ---
MONGO_URI=mongodb://admin:admin123@172.31.11.149:27017/productdb?authSource=admin
MONGO_DB=productdb

# --- AWS ---
AWS_ACCESS_KEY_ID=TU_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=TU_SECRET_KEY
AWS_REGION=us-east-1
S3_BUCKET=openstore-products-637423414138

# --- Seeder ---
NUM_SHOPS=100
PRODUCTS_PER_SHOP=200
USERS_PER_SHOP=100
